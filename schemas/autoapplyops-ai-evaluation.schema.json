{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autoapplyops.local/schemas/autoapplyops-ai-evaluation.schema.json",
  "title": "AutoApplyOps AI Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "aiFitSummary",
    "resumeSignalScore",
    "riskFlags",
    "followUpTone",
    "recommendedAction",
    "confidence",
    "aiStatus",
    "modelUsed",
    "evaluatedAt"
  ],
  "properties": {
    "aiFitSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 420,
      "description": "Plain-language fit summary in 1-3 sentences with no jargon."
    },
    "resumeSignalScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "riskFlags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["flag", "severity"],
        "properties": {
          "flag": {
            "type": "string",
            "enum": [
              "salary_mismatch",
              "location_conflict",
              "role_scope_unclear",
              "duplicate_suspected",
              "missing_resume",
              "unrealistic_timeline",
              "credential_gap"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },
    "followUpTone": {
      "type": "string",
      "enum": ["warm", "neutral", "cautious", "defer"]
    },
    "recommendedAction": {
      "type": "string",
      "enum": ["advance", "hold", "archive", "escalate_to_human"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "aiStatus": {
      "type": "string",
      "enum": ["available", "fallback", "disabled"]
    },
    "modelUsed": {
      "type": "string",
      "minLength": 1
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
