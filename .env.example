# Optional values for a deployed n8n instance.
# The included workflow is credential-free and can be imported without these.
N8N_BASE_URL=http://localhost:5678
AUTOAPPLYOPS_WEBHOOK_SECRET=replace-with-a-shared-secret-in-production
AUTOAPPLYOPS_TARGET_SKILLS=javascript,api,automation,postgresql,node,n8n
OLLAMA_BASE_URL=http://localhost:11434
AUTOAPPLYOPS_AI_MODEL=gemma3:4b
AUTOAPPLYOPS_AI_ENABLED=false
FEEDBACK_DB_PATH=data/feedback.db
NODE_ENV=development
